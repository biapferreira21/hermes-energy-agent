# =============================================================
# HERMES ENERGY AGENT - Configuracao
# Copia este ficheiro para .env e preenche os valores
# NUNCA publiques o .env no GitHub
# =============================================================

# Escolhe o provider: openai, openrouter, ollama
LLM_PROVIDER=openai

# --- OpenAI (recomendado para comecar) ---
OPENAI_API_KEY=sk-coloca-aqui-a-tua-chave
OPENAI_MODEL=gpt-4o-mini

# --- OpenRouter (alternativa barata) ---
OPENROUTER_API_KEY=coloca-aqui-a-tua-chave-openrouter
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Ollama (gratis, local, sem internet) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# --- Base de dados ---
# SQLite para comecar (nao precisa de instalar nada extra)
DATABASE_URL=sqlite:///data/hermes_energy.db
# PostgreSQL quando quiseres escalar (opcional):
# DATABASE_URL=postgresql+psycopg2://hermes:hermes_password@localhost:5432/hermes_energy

# --- Configuracoes de processamento ---
USER_TIMEZONE=Europe/Lisbon
MAX_ARTICLE_CHARS=12000
MIN_ARTICLE_CHARS=300
